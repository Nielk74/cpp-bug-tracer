flowchart TD
    User(["👤 User\nreports C++ bug"])

    subgraph router["🚦 router  ·  entry point"]
        R1["Classify symptom\nEXTERNAL · INTERNAL · UNCLEAR"]
        R2{"Route"}
        R3["Evaluate result\n(file:line cited? fix stated?)"]
        R4["Fallback: run other pipeline\nwith prior findings as context"]
        R5["Write final report"]
    end

    subgraph cst["🔗 cross-source-tracer  ·  API / queue / registry changes"]
        CST1["Extract domain noun\n(fee · credit · queue · settlement)"]
        CST2["Find SOURCE file\n(API client · queue consumer)"]
        CST3["Find PARSER file"]
        CST4["Diff contracts\n(field names · indices · encoding)"]
    end

    subgraph bugtracer["🐛 cpp-bug-tracer  ·  intra-codebase logic bugs"]
        O1["Classify bug type\n(event · counter · unit · ID\n· conditional · cross-layer)"]
        O2["Build Thread A & B prompts"]

        subgraph abstractor["🔬 abstractor"]
            A1["Spawn Thread A & B\nin parallel"]
            A2["Synthesize findings"]
        end

        subgraph investigators["🔍 investigator ×2"]
            I1["Thread A\nTrace call chain"]
            I2["Thread B\nTrace call chain"]
        end
    end

    Codebase[("📁 C++ codebase")]
    Report(["📄 Bug report\n(root cause · file:line · fix)"])

    User --> R1
    R1 --> R2

    R2 -->|EXTERNAL| CST1
    R2 -->|INTERNAL| O1
    R2 -->|UNCLEAR| CST1
    R2 -->|UNCLEAR| O1

    CST1 --> CST2
    CST2 <-->|"glob · read"| Codebase
    CST2 --> CST3
    CST3 <-->|"glob · read"| Codebase
    CST3 --> CST4
    CST4 -->|findings| R3

    O1 --> O2
    O2 --> A1
    A1 --> I1
    A1 --> I2
    I1 <-->|"grep · read"| Codebase
    I2 <-->|"grep · read"| Codebase
    I1 -->|findings| A2
    I2 -->|findings| A2
    A2 -->|findings| R3

    R3 -->|"root cause found"| R5
    R3 -->|"nothing found\n→ try other pipeline"| R4
    R4 -->|"with prior context"| CST1
    R4 -->|"with prior context"| O1
    R5 --> Report

